# Public application environment labels exposed to the corresponding clients.
NEXT_PUBLIC_APP_ENV=development
TARO_APP_ENV=development

# Mini Program API origin. Keep the local Admin origin for the default development setup.
TARO_APP_API_BASE_URL=http://localhost:3000

# Local PostgreSQL 18 container settings. These public values are for local development only.
POSTGRES_USER=violin_dev
POSTGRES_PASSWORD=violin_local_only
POSTGRES_DB=violin_erp_lite
POSTGRES_PORT=5432

# Prisma CLI and server-side database connection. Keep it aligned with the local settings above.
DATABASE_URL=postgresql://violin_dev:violin_local_only@localhost:5432/violin_erp_lite?schema=public

# Server-only JWT values. Generate two different random values; never commit populated secrets.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Idempotent development Seed. The password is mandatory and must remain only in the untracked .env.
SEED_ADMIN_USERNAME=dev-admin
SEED_ADMIN_DISPLAY_NAME=开发管理员
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Local upload storage and byte limit. Production storage is supplied by an adapter.
UPLOAD_STORAGE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE=10485760
