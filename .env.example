# Public technical environment labels. Keep real values in untracked files.
NEXT_PUBLIC_APP_ENV=
TARO_APP_ENV=

# PostgreSQL connection used by Prisma CLI and server-side database access.
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE?schema=public

# Server-only authentication values. Replace placeholders outside Git.
JWT_ACCESS_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_32_CHARACTER_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Local development upload storage. Production storage is supplied by an adapter.
UPLOAD_STORAGE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE=10485760
