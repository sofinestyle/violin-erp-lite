{
  "name": "violin-erp-lite",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev:admin": "pnpm --filter @violin-erp/admin dev",
    "dev:miniapp": "pnpm --filter @violin-erp/miniapp dev",
    "build:admin": "pnpm --filter @violin-erp/admin build",
    "build:miniapp": "pnpm --filter @violin-erp/miniapp build",
    "workspace:list": "pnpm list --recursive --depth -1"
  }
}
